{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/health.js"
    },
    {
      "src": "/api/check-key",
      "dest": "api/check-key.js"
    },
    {
      "src": "/api/activate",
      "dest": "api/activate.js"
    },
    {
      "src": "/api/verify-hwid",
      "dest": "api/verify-hwid.js"
    },
    {
      "src": "/api/heartbeat",
      "dest": "api/heartbeat.js"
    }
  ]
}
